# Solar Stock Management - Environment Configuration
# Copy to .env and fill in your values

# Server Configuration
HOST=127.0.0.1
PORT=8000
RELOAD=false

# Security
SECRET_KEY=change-this-to-a-random-64-char-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_SALT=change-this-to-a-random-salt

# Email SMTP Configuration (optional - can also be set via Settings UI)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# Paths (relative to project root)
STOCK_FILE_PATH=data/stock.json
REPORTS_DIR=reports
LOGS_DIR=logs
IMAGES_DIR=data/images
